{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "wisprflow",
  "mainBinaryName": "wisprflow",
  "version": "0.1.0",
  "identifier": "com.wisprflow.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:frontend"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "wisprflow",
        "width": 1360,
        "height": 920,
        "minWidth": 1080,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": false
      },
      {
        "label": "pill",
        "url": "pill.html",
        "title": "",
        "width": 168,
        "height": 44,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/wisprtype-stt-worker",
      "binaries/wisprtype-refinement-worker"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
