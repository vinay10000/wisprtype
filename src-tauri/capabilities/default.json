{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "pill"
  ],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-ignore-cursor-events",
    "core:event:default"
  ]
}
